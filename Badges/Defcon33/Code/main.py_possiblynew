# Uses int for color and cent is a percentage
def rainbow(color, cent):
    val = int(255 * cent)
    #red
    if color == 1:
        triLight(val,0,0)
        aw20x_red(val)
    #orange
    if color == 2:
        triLight(int(255*cent),int(80*cent),0)
        aw20x_red(val)
        aw20x_green(int(80*cent))
        aw20x_blue(0)
    #yellow
    if color == 3:
        triLight(int(255*cent),int(255*cent),0)
        aw20x_red(val)
        aw20x_green(val)
        aw20x_blue(0)
    #green
    if color == 4:
        triLight(0,val,0)
        aw20x_red(0)
        aw20x_green(int(80*cent))
        aw20x_blue(0)
    #blue
    if color == 5:
        triLight(0,0,val)
        aw20x_red(0)
        aw20x_green(0)
        aw20x_blue(val)
    #indigo
    if color == 6:
        triLight(int(75*cent),0,int(130*cent))
        aw20x_red(int(75*cent))
        aw20x_green(0)
        aw20x_blue(int(130*cent))
    #violet
    if color == 7:
        triLight(int(148*cent),0,int(211*cent))
        aw20x_red(int(148*cent))
        aw20x_green(0)
        aw20x_blue(int(211*cent))
    #off
    if color == 9:
        triLight(0,0,0)
        aw20x_red(0)
        aw20x_green(0)
        aw20x_blue(0)


