    val = sound_btn.value()
    now = time.ticks_ms()

    if val == 0 and sound_btn_state == 1:  # Button pressed
        sound_btn_down_time = now
        sound_last_press_handled = False


    elif val == 1 and sound_btn_state == 0:  # Button released
        if sound_btn_down_time is not None:
            held_ms = time.ticks_diff(now, sound_btn_down_time)
            if not sound_last_press_handled and held_ms > SOUND_TOGGLE_DEBOUNCE_MS:
                sound_enabled = not sound_enabled
                print("Sound is now", "ENABLED" if sound_enabled else "DISABLED")
                if sound_enabled:
