def update_breathing_rainbow():
    global _breathing_color, _breathing_step, _breathing_last_switch, _breathing_pause

    now = time.ticks_ms()

    if _breathing_pause:
        # Check if pause between colors is over
        if time.ticks_diff(now, _breathing_last_switch) > int(PAUSE_BETWEEN_COLORS * 1000):
            _breathing_pause = False
            _breathing_last_switch = now
        else:
            return  # Still pausing; do nothing

    # Do one breath step
    percent = breathe_curve[_breathing_step]
    #rainbow(_breathing_color, percent)
    #rainbow(color_index, brightness_levels[brightness_index])
    rainbow(_breathing_color, breathe_curve[_breathing_step])


    np.write()  # If needed

    # Advance step
    _breathing_step += 1
    if _breathing_step >= len(breathe_curve):
        _breathing_step = 0
        _breathing_color += 1
        if _breathing_color > len(RAINBOW_COLORS):
            _breathing_color = 1
        _breathing_pause = True
        _breathing_last_switch = now

def start_audio(num):
    """Queues up the sound; will play if not already playing."""
    global audio_queue
    if not sound_enabled:
        print("Sound is disabled!")
        return
    # Prevent duplicate requests for the same sound
    if audio_queue and audio_queue[-1] == num:
        print("Audio already queued, skipping duplicate")
        return
    audio_queue.append(num)

def update_audio():
    """Call this every loop to advance audio playback."""
    global audio_playing, audio_file, audio_queue

    if not audio_playing:
        if not audio_queue:
            return  # Nothing to do

        # Start playing next queued audio
        num = audio_queue.pop(0)

        # Select filename
        if num == 1:
            play = "tada.wav"
        elif num == 2:
            play = "Swing1.wav"
        elif num == 3:
            play = "Swing2.wav"
        elif num == 4:
            play = "Swing3.wav"
        elif num == 5:
            play = "listen.wav"
        else:
            return  # Invalid number

        audio_file = open(play, "rb")
        audio_file.read(44)  # Skip header
        audio_playing = True

    # Play next chunk
    if audio_file:
        data = audio_file.read(1024)
        if data:
            i2s.write(data)
        else:
            audio_file.close()
            audio_file = None
            audio_playing = False

