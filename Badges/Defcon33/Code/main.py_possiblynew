def poll_button():
    global button_state, button_down_time, last_press_handled

    val = btn.value()
    now = time.ticks_ms()

    if val == 0 and button_state == 1:  # Button pressed
        button_down_time = now
        last_press_handled = False

    elif val == 1 and button_state == 0:  # Button released
        if button_down_time is not None:
            held_ms = time.ticks_diff(now, button_down_time)
            if not last_press_handled:
                if held_ms < LONG_PRESS_MS:
                    handle_short_press()
                else:
                    handle_long_press()
            button_down_time = None

    elif val == 0 and button_state == 0 and button_down_time is not None:
        # Still being held, check for long press
        held_ms = time.ticks_diff(now, button_down_time)
        if not last_press_handled and held_ms >= LONG_PRESS_MS:
            handle_long_press()
            last_press_handled = True

    button_state = val


def poll_sound_button():
