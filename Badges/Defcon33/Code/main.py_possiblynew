def build_breathe_curve():
    min_bright = 0.1
    max_bright = brightness_levels[brightness_index]
    curve = [
        min_bright + (max_bright - min_bright) * (math.sin(math.pi * i / BREATHE_STEPS) ** 2)
        for i in range(BREATHE_STEPS)
    ] + [
        min_bright + (max_bright - min_bright) * (math.sin(math.pi * i / BREATHE_STEPS) ** 2)
        for i in reversed(range(BREATHE_STEPS))
    ]
    return curve

